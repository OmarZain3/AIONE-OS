# =============================================================================
# AIONE — Environment Configuration (Example)
# =============================================================================
# Copy this file to `.env` and adjust values for your local environment.
# Never commit `.env` or files containing real secrets.
#
#   cp .env.example .env
# =============================================================================

# --- General -----------------------------------------------------------------
COMPOSE_PROJECT_NAME=aione
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-long-random-string

# --- Backend (placeholder) ---------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_LOG_LEVEL=info

# --- Frontend (placeholder) --------------------------------------------------
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aione
POSTGRES_USER=aione
POSTGRES_PASSWORD=change_me

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Connection URLs (consumed by application services) ------------------------
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- JWT Authentication --------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
