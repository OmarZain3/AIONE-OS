# =============================================================================
# AIONE — Enterprise Monorepo .gitignore
# =============================================================================

# --- Environment & secrets ---------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# --- OS-generated files ------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# --- Editor & IDE ------------------------------------------------------------
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
*.swp
*.swo
*~
.project
.classpath
.settings/

# --- Logs & runtime ----------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Dependencies ------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
env/
.python-version

# --- Build & test artifacts --------------------------------------------------
coverage/
.coverage
.coverage.*
htmlcov/
.nyc_output/
*.lcov
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
junit.xml
test-results/
playwright-report/
blob-report/

# --- Docker ------------------------------------------------------------------
docker-compose.override.yml
docker-compose.local.yml

# --- Infrastructure & local data ---------------------------------------------
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfvars
!*.tfvars.example

# --- Misc --------------------------------------------------------------------
*.bak
*.tmp
*.temp
.cache/
.turbo/
.next/
.nuxt/
.output/
.vercel/
*.tsbuildinfo
